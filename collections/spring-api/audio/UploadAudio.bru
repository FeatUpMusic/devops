meta {
  name: Upload Audio File
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/audio/upload
  body: multipart-form
  auth: bearer
}

headers {
  Authorization: Bearer {{token_A}}
}

body:multipart-form {
  file: @file(sample.mp3)
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("audio_id", res.body.id);
  }
}
