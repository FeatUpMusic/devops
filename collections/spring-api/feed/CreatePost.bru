meta {
  name: Create Post
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/feed
  body: json
  auth: bearer
}

headers {
  Authorization: Bearer {{token_A}}
}

body:json {
  {
    "title": "My New Electronic Beat",
    "content": "Check out this fresh prototype I uploaded! Collab offers welcome.",
    "audioClipId": {{audio_id}}
  }
}

script:post-response {
  if (res.status === 201 || res.status === 200) {
    bru.setVar("post_id", res.body.id);
  }
}
