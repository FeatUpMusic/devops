meta {
  name: Login User B
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/identity/login
  body: json
  auth: none
}

body:json {
  {
    "alias": "{{alias_B}}",
    "password": "secure_password_B"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("token_B", res.body.token);
    bru.setVar("userB_id", res.body.userId);
  }
}
